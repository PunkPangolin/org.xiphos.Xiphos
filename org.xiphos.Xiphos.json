{
    "id": "org.xiphos.Xiphos",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "xiphos",
    "rename-desktop-file": "xiphos.desktop",
    "rename-icon": "xiphos",
    "rename-appdata-file": "xiphos.appdata.xml",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--persist=.sword",
        "--persist=.xiphos",
        "--talk-name=org.gnome.GConf",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "*.a",
        "*.la",
        "/lib/pkgconfig",
        "/share/gtk-doc",
        "/share/pkgconfig"
    ],
    "modules": [
        "shared-modules/dbus-glib/dbus-glib.json",
        {
            "name": "biblesync",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON",
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/karlkleinpaste/biblesync/releases/download/2.1.0/biblesync-2.1.0.tar.gz",
                    "sha256": "9083fcacc4d85f2b8c3a3254112129c02d940d20db8c0c5bcb6239b115e8d0e8",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 15373,
                        "url-template": "https://github.com/karlkleinpaste/biblesync/releases/download/$version/biblesync-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "sword",
            "sources": [
                {
                    "type": "archive",
                    "url": "http://crosswire.org/ftpmirror/pub/sword/source/v1.9/sword-1.9.0.tar.gz",
                    "sha256": "42409cf3de2faf1108523e2c5ac0745d21f9ed2a5c78ed878ee9dcc303426b8a",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 16287,
                        "url-template": "http://crosswire.org/ftpmirror/pub/sword/source/v${version0}.${version1}/sword-$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "minizip",
            "subdir": "contrib/minizip",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://zlib.net/zlib-1.3.2.tar.gz",
                    "sha256": "bb329a0a2cd0274d05519d61c667c062e06990d72e125ee2dfa8de64f0119d16",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 5303,
                        "url-template": "https://zlib.net/zlib-$version.tar.gz"
                    }
                },
                {
                    "type": "patch",
                    "path": "patches/minizip-include-ints_h.patch"
                },
                {
                    "type": "script",
                    "dest": "contrib/minizip",
                    "dest-filename": "autogen.sh",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        },
        {
            "name": "appstream",
            "buildsystem": "meson",
            "config-opts": [
                "-Drpm=false"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/hughsie/appstream-glib/archive/refs/tags/appstream_glib_0_8_3.tar.gz",
                    "sha256": "15ad7690b0132d883bd066699a7b55f6cef4c0f266d18d781ce5d8112fb4ee63",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 14018,
                        "url-template": "https://github.com/hughsie/appstream-glib/archive/refs/tags/appstream_glib_${version0}_${version1}_${version2}.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "xiphos",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/crosswire/xiphos/releases/download/4.3.2/xiphos-4.3.2.tar.xz",
                    "sha256": "2c10f6bb9f72b0d49e0abfde6867a825e620bdd8561bf115758713201cdd80a7",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 372425,
                        "url-template": "https://github.com/crosswire/xiphos/releases/download/$version/xiphos-$version.tar.xz"
                    }
                },
                {
                    "type": "patch",
                    "path": "patches/xiphos-build.patch"
                },
                {
                    "type": "patch",
                    "path": "patches/xiphos-fix-appdata-file.patch"
                }
            ]
        }
    ]
}
